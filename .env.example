# Discord 앱 설정 (https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# NEON PostgreSQL 연결 문자열 (https://console.neon.tech)
NEON_DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# 세션 시크릿 (랜덤 긴 문자열)
SESSION_SECRET=

# 서버 포트 (Render는 자동 설정, 로컬은 8080)
PORT=8080
